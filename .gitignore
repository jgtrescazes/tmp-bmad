# =============================================================================
# .gitignore - Platform Monitoring
# Based on Claude Code & BMAD best practices
# =============================================================================

# -----------------------------------------------------------------------------
# Claude Code
# -----------------------------------------------------------------------------
# Local settings (user-specific, not shared)
.claude/settings.local.json

# Claude Code auto-memory (session-specific, not shared)
# Note: ~/.claude/projects/ is outside repo, but if copied locally:
.claude/memory/

# -----------------------------------------------------------------------------
# BMAD Framework
# -----------------------------------------------------------------------------
# BMAD core - not versioned
_bmad/

# BMAD output artifacts - typically tracked, but uncomment if you prefer not to
# _bmad-output/

# BMAD agent memory - can contain session-specific state
# Uncomment if you don't want to share agent memory across team
# _bmad/_memory/

# Temporary BMAD working files
_bmad-temp/
*.bmad.tmp

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
# JetBrains IDEs (IntelliJ, WebStorm, etc.)
.idea/*
!.idea/codeStyles/
!.idea/inspectionProfiles/
!.idea/runConfigurations/
.idea/*.iml

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.#*

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Linux
# -----------------------------------------------------------------------------
*~
.directory

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.pem
*.key
secrets/
credentials/

# -----------------------------------------------------------------------------
# Dependencies (Node.js)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json.bak
yarn.lock.bak

# -----------------------------------------------------------------------------
# Dependencies (Python)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
ENV/
env/
.eggs/
*.egg-info/
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Build & Output
# -----------------------------------------------------------------------------
dist/
build/
out/
.output/
.next/
.nuxt/
.cache/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
.pytest_cache/
htmlcov/
junit.xml
test-results/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
