  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^3.17.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "supabase": "^2.22.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.4",
